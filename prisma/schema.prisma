generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LanguageCode {
  fr
  en
}

enum Role {
  TOP
  JUNGLE
  MID
  ADC
  SUPPORT
  FLEX
}

enum PuzzleDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum PuzzleChoiceType {
  ITEM
  COMPONENT
  BUILD_PATH
  BOOTS
  SITUATIONAL_DECISION
}

enum PuzzleMode {
  GENERAL
  CHAMPION_SPECIFIC
  PERSONALIZED
  DAILY
}

enum PuzzleSourceType {
  MANUAL
  GENERATED
  IMPORTED_MATCH
  AI_GENERATED
}

enum UserAuthProvider {
  EMAIL
  GOOGLE
  BOTH
}

enum GeneratedPuzzleRequestType {
  CHAMPION
  MATCH_BASED
  CUSTOM
}

enum GeneratedPuzzleRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id               String                    @id @default(cuid())
  email            String                    @unique
  username         String                    @unique
  isAdmin          Boolean                   @default(false)
  authProvider     UserAuthProvider          @default(EMAIL)
  passwordHash     String?
  googleId         String?                   @unique
  avatarUrl        String?
  language         LanguageCode              @default(fr)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  attempts         PuzzleAttempt[]
  championProgress UserChampionProgress[]
  globalProgress   UserGlobalProgress?
  dailyCompletions DailyChallengeCompletion[]
  playerProfile    PlayerProfile?
  importedMatches  ImportedMatch[]
  generatedPuzzles GeneratedPuzzleRequest[]
  emailPreference  EmailReminderPreference?

  @@index([username])
  @@index([email])
  @@index([googleId])
}

model Champion {
  id             String                 @id @default(cuid())
  riotChampionId Int?                   @unique
  championKey    String?                @unique
  name           String
  slug           String                 @unique
  title          String?
  rolePrimary    Role?
  roleSecondary  Role?
  image          String
  splashImage    String?
  iconImage      String?
  tags           Json
  stats          Json
  isActive       Boolean                @default(true)
  patch          String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  puzzles        Puzzle[]
  scenarioPlayer PuzzleScenario[]       @relation("PuzzleScenarioPlayerChampion")
  userProgress   UserChampionProgress[]
  generatedRequests GeneratedPuzzleRequest[]

  @@index([slug])
  @@index([name])
  @@index([riotChampionId])
  @@index([rolePrimary])
  @@index([patch])
}

model Item {
  id              String         @id @default(cuid())
  riotItemId      Int            @unique
  name            String
  slug            String         @unique
  shortDescription String?
  fullDescription String?
  image           String
  goldTotal       Int
  goldBase        Int?
  goldSell        Int?
  category        String?
  tags            Json
  stats           Json
  activeEffect    String?
  passiveEffect   String?
  buildsFrom      Json
  buildsInto      Json
  mapAvailability Json?
  isBoots         Boolean        @default(false)
  isLegendary     Boolean        @default(false)
  isConsumable    Boolean        @default(false)
  isTrinket       Boolean        @default(false)
  isStarter       Boolean        @default(false)
  isActive        Boolean        @default(true)
  patch           String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  puzzleChoices   PuzzleChoice[]

  @@index([slug])
  @@index([name])
  @@index([riotItemId])
  @@index([patch])
  @@index([isBoots])
}

model Puzzle {
  id              String                 @id @default(cuid())
  title           String
  slug            String                 @unique
  mode            PuzzleMode
  sourceType      PuzzleSourceType
  difficulty      PuzzleDifficulty
  patch           String
  description     String
  shortPrompt     String
  situation       String
  question        String
  explanation     String
  role            Role?
  championId      String?
  isPublished     Boolean                @default(false)
  isDailyEligible Boolean                @default(true)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  champion        Champion?              @relation(fields: [championId], references: [id])
  choices         PuzzleChoice[]
  scenario        PuzzleScenario?
  tags            PuzzleTagOnPuzzle[]
  attempts        PuzzleAttempt[]
  dailyChallenges DailyChallenge[]
  generatedFrom   GeneratedPuzzleRequest[]

  @@index([slug])
  @@index([championId])
  @@index([isPublished])
  @@index([mode])
  @@index([difficulty])
  @@index([patch])
}

model PuzzleChoice {
  id           String           @id @default(cuid())
  puzzleId      String
  label         String
  choiceType    PuzzleChoiceType
  itemId        String?
  textFallback  String?
  explanation   String
  isCorrect     Boolean         @default(false)
  displayOrder  Int
  puzzle        Puzzle          @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  item          Item?           @relation(fields: [itemId], references: [id])
  attempts      PuzzleAttempt[]

  @@index([puzzleId])
  @@index([itemId])
  @@index([displayOrder])
}

model PuzzleScenario {
  id              String    @id @default(cuid())
  puzzleId         String    @unique
  playerChampionId String
  playerRole       Role
  gameMinute       Int
  playerGold       Int
  playerLevel      Int?
  kills            Int?
  deaths           Int?
  assists          Int?
  cs               Int?
  currentBuild     Json
  allyTeam         Json
  enemyTeam        Json
  allyItems        Json?
  enemyItems       Json?
  notableThreats   Json?
  objectiveState   Json?
  damageProfile    Json?
  mapState         Json?
  notes            String?
  puzzle           Puzzle    @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  playerChampion   Champion  @relation("PuzzleScenarioPlayerChampion", fields: [playerChampionId], references: [id])

  @@index([playerChampionId])
  @@index([playerRole])
}

model PuzzleTag {
  id        String            @id @default(cuid())
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now())
  puzzles   PuzzleTagOnPuzzle[]

  @@index([slug])
  @@index([name])
}

model PuzzleTagOnPuzzle {
  puzzleId String
  tagId    String
  puzzle   Puzzle    @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  tag      PuzzleTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([puzzleId, tagId])
  @@index([puzzleId])
  @@index([tagId])
}

model PuzzleAttempt {
  id               String       @id @default(cuid())
  userId           String
  puzzleId         String
  selectedChoiceId String
  isCorrect        Boolean
  answeredAt       DateTime     @default(now())
  responseTimeMs   Int?
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  puzzle           Puzzle       @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  selectedChoice   PuzzleChoice @relation(fields: [selectedChoiceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([puzzleId])
  @@index([selectedChoiceId])
  @@index([answeredAt])
}

model UserChampionProgress {
  id             String    @id @default(cuid())
  userId         String
  championId     String
  totalAttempts  Int       @default(0)
  correctAttempts Int      @default(0)
  masteryScore   Int?
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  champion       Champion  @relation(fields: [championId], references: [id], onDelete: Cascade)

  @@unique([userId, championId])
  @@index([userId])
  @@index([championId])
}

model UserGlobalProgress {
  id                   String    @id @default(cuid())
  userId               String    @unique
  totalAttempts        Int       @default(0)
  totalCorrect         Int       @default(0)
  dailyStreak          Int       @default(0)
  bestStreak           Int       @default(0)
  lastDailyCompletedAt DateTime?
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyChallenge {
  id            String                   @id @default(cuid())
  puzzleId       String
  challengeDate  DateTime                @unique
  createdAt      DateTime                @default(now())
  puzzle         Puzzle                  @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  completions    DailyChallengeCompletion[]

  @@index([challengeDate])
}

model DailyChallengeCompletion {
  id               String         @id @default(cuid())
  dailyChallengeId String
  userId           String
  completedAt      DateTime       @default(now())
  isCorrect        Boolean
  dailyChallenge   DailyChallenge @relation(fields: [dailyChallengeId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dailyChallengeId, userId])
  @@index([dailyChallengeId])
  @@index([userId])
}

model PlayerProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  riotPuuid     String?
  riotGameName  String?
  riotTagLine   String?
  region        String?
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RiotAccountIndex {
  id             String   @id @default(cuid())
  puuid          String   @unique
  gameName       String
  tagLine        String
  normalizedRiotId String
  platform       String?
  region         String?
  profileIconId  Int?
  summonerLevel  Int?
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([gameName, tagLine])
  @@index([normalizedRiotId])
  @@index([gameName])
  @@index([tagLine])
  @@index([lastSeenAt])
}

model ImportedMatch {
  id                  String    @id @default(cuid())
  userId              String
  riotMatchId         String    @unique
  patch               String?
  sourceRegion        String?
  sourceKind          String?
  sourceMetadata      Json?
  targetPuuid         String?
  targetGameName      String?
  targetTagLine       String?
  targetChampionId    Int?
  targetChampionSlug  String?
  targetRole          Role?
  gameCreationAt      DateTime?
  gameDurationSeconds Int?
  timelineFetchedAt   DateTime?
  timelineMissingReason String?
  matchData           Json
  timelineData        Json?
  createdAt           DateTime  @default(now())
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests            GeneratedPuzzleRequest[]

  @@index([userId])
  @@index([riotMatchId])
  @@index([patch])
  @@index([sourceRegion])
  @@index([sourceKind])
  @@index([targetPuuid])
  @@index([targetChampionSlug])
  @@index([targetRole])
  @@index([gameCreationAt])
}

model GeneratedPuzzleRequest {
  id              String                       @id @default(cuid())
  userId          String
  type            GeneratedPuzzleRequestType
  championId      String?
  importedMatchId String?
  parameters      Json
  status          GeneratedPuzzleRequestStatus @default(PENDING)
  resultPuzzleId  String?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  user            User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  champion        Champion?                    @relation(fields: [championId], references: [id])
  importedMatch   ImportedMatch?               @relation(fields: [importedMatchId], references: [id])
  resultPuzzle    Puzzle?                      @relation(fields: [resultPuzzleId], references: [id])

  @@index([userId])
  @@index([championId])
  @@index([importedMatchId])
  @@index([status])
}

model EmailReminderPreference {
  id                   String    @id @default(cuid())
  userId               String    @unique
  dailyReminderEnabled Boolean   @default(true)
  preferredHour        Int?
  timezone             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
